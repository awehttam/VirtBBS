<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VirtBBS.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="550"
             x:Class="VirtBBS.GUI.Views.UsersView"
             x:DataType="vm:UsersViewModel">

    <Grid Margin="10" ColumnDefinitions="2*,8,1*" RowDefinitions="*">

        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                <Button Content="Refresh" Command="{Binding LoadCommand}"/>
                <TextBox Text="{Binding SearchQuery}" Width="200" PlaceholderText="Search name/city..."/>
                <Button Content="Search" Command="{Binding SearchCommand}"/>
            </StackPanel>

            <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                      IsReadOnly="True" GridLinesVisibility="Horizontal" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"     Binding="{Binding Name}"          Width="160"/>
                    <DataGridTextColumn Header="City"     Binding="{Binding City}"          Width="140"/>
                    <DataGridTextColumn Header="Security" Binding="{Binding SecurityLevel}" Width="80"/>
                    <DataGridTextColumn Header="Calls"     Binding="{Binding TimesOnline}"   Width="60"/>
                    <DataGridCheckBoxColumn Header="Sysop" Binding="{Binding Sysop}"         Width="60"/>
                    <DataGridCheckBoxColumn Header="Del"   Binding="{Binding Deleted}"       Width="50"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="8" Background="Transparent"/>

        <ScrollViewer Grid.Column="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="6">
                <TextBlock Text="Edit User" FontWeight="Bold"/>
                <TextBlock Text="City:"/>
                <TextBox Text="{Binding EditCity}"/>
                <TextBlock Text="Phone:"/>
                <TextBox Text="{Binding EditPhone}"/>
                <TextBlock Text="Security Level:"/>
                <NumericUpDown Value="{Binding EditSecurity}" Minimum="0" Maximum="999"/>
                <TextBlock Text="Page Length:"/>
                <NumericUpDown Value="{Binding EditPageLength}" Minimum="0" Maximum="99"/>
                <CheckBox Content="ANSI" IsChecked="{Binding EditAnsi}"/>
                <CheckBox Content="Sysop" IsChecked="{Binding EditSysop}"/>
                <CheckBox Content="Deleted" IsChecked="{Binding EditDeleted}"/>
                <TextBlock Text="Editor Type:"/>
                <ComboBox SelectedItem="{Binding EditEditorType}" HorizontalAlignment="Stretch">
                    <ComboBox.Items>
                        <x:String>simple</x:String>
                        <x:String>full</x:String>
                    </ComboBox.Items>
                </ComboBox>
                <TextBlock Text="Comment:"/>
                <TextBox Text="{Binding EditComment}" AcceptsReturn="True" Height="60" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="Save"   Command="{Binding SaveCommand}"/>
                    <Button Content="Delete" Command="{Binding DeleteCommand}"/>
                </StackPanel>
                <TextBlock Text="{Binding Status}" Opacity="0.8" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
