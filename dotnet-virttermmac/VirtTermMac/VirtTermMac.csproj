<Project Sdk="Microsoft.NET.Sdk">
  <!--
    VirtTermMac — a macOS-native (and cross-platform: Linux/Windows too)
    Avalonia UI port of dotnet-virtterm/VirtTerm (WinForms, Windows-only).
    Connects to the same internal/virtterm TLS transport and internal/userapi
    token API as VirtTerm; see ../README.md for what changed in the port.
  -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>VirtTermMac</AssemblyName>
    <RootNamespace>VirtTermMac</RootNamespace>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.0.5" />
    <PackageReference Include="Avalonia.Desktop" Version="12.0.5" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.5" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="12.0.5" />
  </ItemGroup>
</Project>
