<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VirtBBS.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="650"
             x:Class="VirtBBS.GUI.Views.ConfigView"
             x:DataType="vm:ConfigViewModel">

    <ScrollViewer Margin="10">
        <StackPanel Spacing="6" MaxWidth="480">

            <TextBlock Text="BBS" FontWeight="Bold" Margin="0,8,0,0"/>
            <TextBlock Text="Name:"/>
            <TextBox Text="{Binding BbsName}"/>
            <TextBlock Text="Max Nodes:"/>
            <NumericUpDown Value="{Binding MaxNodes}" Minimum="1" Maximum="999"/>

            <TextBlock Text="Network" FontWeight="Bold" Margin="0,12,0,0"/>
            <TextBlock Text="Telnet Port:"/>
            <NumericUpDown Value="{Binding TelnetPort}" Minimum="1" Maximum="65535"/>
            <TextBlock Text="SSH Port:"/>
            <NumericUpDown Value="{Binding SshPort}" Minimum="1" Maximum="65535"/>
            <TextBlock Text="API Port:"/>
            <NumericUpDown Value="{Binding ApiPort}" Minimum="1" Maximum="65535"/>
            <TextBlock Text="API Bind:"/>
            <TextBox Text="{Binding ApiBind}"/>
            <TextBlock Text="User API Port (VirtAnd/VirtTerm):"/>
            <NumericUpDown Value="{Binding UserApiPort}" Minimum="1" Maximum="65535"/>
            <TextBlock Text="User API Bind:"/>
            <TextBox Text="{Binding UserApiBind}"/>
            <TextBlock Text="VirtTerm Port (TLS):"/>
            <NumericUpDown Value="{Binding VirtTermPort}" Minimum="1" Maximum="65535"/>
            <TextBlock Text="VirtTerm Bind:"/>
            <TextBox Text="{Binding VirtTermBind}"/>
            <TextBlock Text="Web Port (HTTP):"/>
            <NumericUpDown Value="{Binding WebPort}" Minimum="1" Maximum="65535"/>
            <TextBlock Text="Web Bind:"/>
            <TextBox Text="{Binding WebBind}"/>

            <TextBlock Text="Paths" FontWeight="Bold" Margin="0,12,0,0"/>
            <TextBlock Text="Database:"/>
            <TextBox Text="{Binding DbPath}"/>
            <TextBlock Text="Files:"/>
            <TextBox Text="{Binding FilesPath}"/>
            <TextBlock Text="Logs:"/>
            <TextBox Text="{Binding LogsPath}"/>
            <TextBlock Text="Web Root (www):"/>
            <TextBox Text="{Binding WwwPath}"/>

            <TextBlock Text="Session" FontWeight="Bold" Margin="0,12,0,0"/>
            <TextBlock Text="Time Per Call (mins):"/>
            <NumericUpDown Value="{Binding TimePerCallMins}" Minimum="0" Maximum="9999"/>
            <TextBlock Text="Idle Timeout (mins):"/>
            <NumericUpDown Value="{Binding IdleTimeoutMins}" Minimum="0" Maximum="9999"/>
            <TextBlock Text="Max Failed Logins:"/>
            <NumericUpDown Value="{Binding MaxFailedLogins}" Minimum="1" Maximum="99"/>
            <TextBlock Text="New User Security:"/>
            <NumericUpDown Value="{Binding NewUserSecurity}" Minimum="0" Maximum="999"/>

            <TextBlock Text="Sysop" FontWeight="Bold" Margin="0,12,0,0"/>
            <TextBlock Text="Name:"/>
            <TextBox Text="{Binding SysopName}"/>

            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,16,0,0">
                <Button Content="Reload" Command="{Binding LoadCommand}"/>
                <Button Content="Save" Command="{Binding SaveCommand}"/>
            </StackPanel>
            <TextBlock Text="{Binding Status}" Opacity="0.8" TextWrapping="Wrap"/>

        </StackPanel>
    </ScrollViewer>

</UserControl>
