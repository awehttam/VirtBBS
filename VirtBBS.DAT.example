[network]
  telnet_port = 2323
  ssh_port = 3232
  api_port = 9999
  api_bind = "0.0.0.0"
  userapi_port = 9998
  userapi_bind = "0.0.0.0"
  virtterm_port = 6323
  virtterm_bind = "0.0.0.0"
  web_port = 8081
  web_bind = "0.0.0.0"

[paths]
  db          = "data/virtbbs.db"
  files       = "files"
  logs        = "logs"
  caller_log  = "logs/CALLERS.LOG"
  www         = "www"

[sysop]
  name = "Sysop"
  # bcrypt hash of the sysop password — generate your own, do not commit a real hash.
  password = ""

[bbs]
  name      = "My VirtBBS"
  max_nodes = 10

[session]
  idle_timeout_mins  = 5
  time_per_call_mins = 60
  display_dir        = "display"
  new_user_security  = 10

[fido]
  name         = "FidoNet"
  enabled      = false
  address      = "1:1/1"
  uplink       = ""
  password     = ""
  inbound_dir  = "fido/inbound"
  outbound_dir = "fido/outbound"
  nodelist_dir = "fido/nodelist"
  holding_dir  = ""
  areafix_password = ""
  filefix_password = ""
  tic_password = ""

  # Map echomail area tags to VirtBBS conference IDs.
  # Example:
  #   FIDO_GENERAL     = 1
  #   VIRTBBS_SUPPORT  = 2
  [fido.areas]

# Additional FidoNet-compatible networks (optional):
#
# [[fido.networks]]
#   name         = "LovelyNet"
#   enabled      = true
#   address      = "80:774/1"
#   uplink       = "80:774/100"
#   inbound_dir  = "fido/LovelyNet_inbound"
#   outbound_dir = "fido/LovelyNet_outbound"
#   nodelist_dir = "fido/LovelyNet_nodelist"
#   tic_password = ""
#
#   [fido.networks.areas]
#     LOVELY_CHAT = 3

# ── Door Games ────────────────────────────────────────────────────────────────
# Each [[doors]] section defines one door game.
# drop_file can be "DOOR.SYS" (default) or "DORINFO1.DEF"
# Example:
#
# [[doors]]
#   name            = "Lord"
#   description     = "Legend of the Red Dragon"
#   cmd             = "/opt/doors/lord/lord"
#   drop_file       = "DOOR.SYS"
#   append_drop_file = true
#   min_security    = 10
