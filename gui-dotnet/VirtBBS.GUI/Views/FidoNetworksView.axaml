<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VirtBBS.GUI.ViewModels"
             x:Class="VirtBBS.GUI.Views.FidoNetworksView"
             x:DataType="vm:FidoNetworksViewModel">

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <TextBlock Text="Network:" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding NetworkNames}" SelectedItem="{Binding SelectedNetwork}" Width="180"/>
            <Button Content="Reload" Command="{Binding LoadCommand}"/>
            <Button Content="Save Network" Command="{Binding SaveCommand}"/>
            <Button Content="+ Add Network" Command="{Binding AddNetworkCommand}"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Opacity="0.8" TextWrapping="Wrap" Margin="0,8,0,0"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="10" MaxWidth="900">
                <TextBlock Text="Node Settings" FontWeight="Bold" FontSize="14"/>
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Network name:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NetworkName}"/>
                    <CheckBox Grid.Row="1" Grid.Column="1" Content="Enabled" IsChecked="{Binding Enabled}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Address:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Address}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Uplink:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Uplink}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Password:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Password}"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Inbound dir:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding InboundDir}"/>
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Outbound dir:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding OutboundDir}"/>
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Nodelist dir:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding NodelistDir}"/>
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Holding dir:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding HoldingDir}" Watermark="(default: inbound/.holding)"/>
                    <TextBlock Grid.Row="9" Grid.Column="0" Text="BinkP port:" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="9" Grid.Column="1" Value="{Binding BinkpPort}" Minimum="1" Maximum="65535"/>
                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Poll interval (mins):" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="10" Grid.Column="1" Value="{Binding PollIntervalMins}" Minimum="0"/>
                    <TextBlock Grid.Row="11" Grid.Column="0" Text="Nodelist URL:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding NodelistUrl}"/>
                    <TextBlock Grid.Row="12" Grid.Column="0" Text="Nodelist update (hrs):" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="12" Grid.Column="1" Value="{Binding NodelistUpdateIntervalHours}" Minimum="0"/>
                    <TextBlock Grid.Row="13" Grid.Column="0" Text="Nodelist echo tag:" VerticalAlignment="Center" IsVisible="{Binding !IsPrimaryNetwork}"/>
                    <TextBox Grid.Row="13" Grid.Column="1" Text="{Binding NodelistEchoTag}" IsVisible="{Binding !IsPrimaryNetwork}"/>
                    <TextBlock Grid.Row="14" Grid.Column="0" Text="AreaFix password:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="14" Grid.Column="1" Text="{Binding AreafixPassword}"/>
                    <TextBlock Grid.Row="15" Grid.Column="0" Text="FileFix password:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="15" Grid.Column="1" Text="{Binding FilefixPassword}"/>
                    <TextBlock Grid.Row="16" Grid.Column="0" Text="TIC password:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="16" Grid.Column="1" Text="{Binding TicPassword}"/>
                    <TextBlock Grid.Row="17" Grid.Column="0" Text="AKAs (one per line):" VerticalAlignment="Top"/>
                    <TextBox Grid.Row="17" Grid.Column="1" Text="{Binding AkasText}" AcceptsReturn="True" Height="60"/>
                </Grid>

                <TextBlock Text="Inbound Echo Areas ([fido.areas] → conference ID)" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="+ Add Area" Command="{Binding AddInboundAreaCommand}"/>
                </StackPanel>
                <DataGrid ItemsSource="{Binding InboundAreas}" AutoGenerateColumns="False" CanUserReorderColumns="False" Height="120">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Area Tag" Binding="{Binding Tag}" Width="*"/>
                        <DataGridTextColumn Header="Conference ID" Binding="{Binding ConferenceId}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="FileFix Tags ([fido.file_areas] → file dir ID)" FontWeight="Bold"/>
                <Button Content="+ Add File Tag" Command="{Binding AddFileAreaMapCommand}" HorizontalAlignment="Left"/>
                <DataGrid ItemsSource="{Binding FileAreaMaps}" AutoGenerateColumns="False" Height="100">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="FileFix Tag" Binding="{Binding Tag}" Width="*"/>
                        <DataGridTextColumn Header="File Dir ID" Binding="{Binding DirId}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="Downlinks (AreaFix / FileFix)" FontWeight="Bold"/>
                <Button Content="+ Add Downlink" Command="{Binding AddDownlinkCommand}" HorizontalAlignment="Left"/>
                <DataGrid ItemsSource="{Binding Downlinks}" AutoGenerateColumns="False" Height="140">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="140"/>
                        <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="120"/>
                        <DataGridTextColumn Header="Password" Binding="{Binding Password}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="AreaFix Subscriptions (read-only)" FontWeight="Bold"/>
                <DataGrid ItemsSource="{Binding AreaFixSubs}" IsReadOnly="True" AutoGenerateColumns="False" Height="120">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Downlink" Binding="{Binding Downlink}" Width="120"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="140"/>
                        <DataGridTextColumn Header="Areas" Binding="{Binding AreasText}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
