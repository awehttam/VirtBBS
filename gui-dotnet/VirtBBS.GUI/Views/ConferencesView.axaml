<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VirtBBS.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="550"
             x:Class="VirtBBS.GUI.Views.ConferencesView"
             x:DataType="vm:ConferencesViewModel">

    <Grid Margin="10" ColumnDefinitions="2*,8,1*" RowDefinitions="*">

        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                <Button Content="Refresh" Command="{Binding LoadCommand}"/>
                <Button Content="New" Command="{Binding CreateCommand}"/>
                <Button Content="Delete Selected" Command="{Binding DeleteCommand}"/>
            </StackPanel>

            <DataGrid ItemsSource="{Binding Conferences}" SelectedItem="{Binding Selected}"
                      IsReadOnly="True" GridLinesVisibility="Horizontal" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"        Binding="{Binding ID}"         Width="40"/>
                    <DataGridTextColumn Header="Name"      Binding="{Binding Name}"       Width="150"/>
                    <DataGridTextColumn Header="Desc"      Binding="{Binding Description}" Width="*"/>
                    <DataGridCheckBoxColumn Header="Public" Binding="{Binding Public}"     Width="60"/>
                    <DataGridCheckBoxColumn Header="Echo"   Binding="{Binding Echo}"       Width="50"/>
                    <DataGridTextColumn Header="EchoTag"   Binding="{Binding EchoTag}"     Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="8" Background="Transparent"/>

        <ScrollViewer Grid.Column="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="6">
                <TextBlock Text="Edit Conference" FontWeight="Bold"/>
                <TextBlock Text="Name:"/>
                <TextBox Text="{Binding EditName}"/>
                <TextBlock Text="Description:"/>
                <TextBox Text="{Binding EditDescription}"/>
                <CheckBox Content="Public" IsChecked="{Binding EditPublic}"/>
                <TextBlock Text="Read Security:"/>
                <NumericUpDown Value="{Binding EditReadSec}" Minimum="0" Maximum="999"/>
                <TextBlock Text="Write Security:"/>
                <NumericUpDown Value="{Binding EditWriteSec}" Minimum="0" Maximum="999"/>
                <TextBlock Text="Sysop Security:"/>
                <NumericUpDown Value="{Binding EditSysopSec}" Minimum="0" Maximum="999"/>
                <CheckBox Content="Echo (FidoNet)" IsChecked="{Binding EditEcho}"/>
                <TextBlock Text="Echo Tag (AREA:):"/>
                <TextBox Text="{Binding EditEchoTag}"/>
                <TextBlock Text="Uplink Addr (override):"/>
                <TextBox Text="{Binding EditUplinkAddr}"/>
                <TextBlock Text="Network:"/>
                <ComboBox ItemsSource="{Binding NetworkNames}" SelectedItem="{Binding EditNetwork}"/>
                <Button Content="Save" Command="{Binding SaveCommand}"/>
                <TextBlock Text="{Binding Status}" Opacity="0.8" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
